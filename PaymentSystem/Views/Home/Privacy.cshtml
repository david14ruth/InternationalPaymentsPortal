@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="container" style="margin-top:60px; max-width:900px;">

    <h1 class="mb-4 text-primary">@ViewData["Title"]</h1>

    <p class="text-muted">
        At <strong>GlobalTrust</strong>, your privacy and security are our top priorities.
        This Privacy Policy explains how we collect, use, and protect your personal information
        when you use our banking and financial services.
    </p>

    <hr />

    <!-- INFORMATION WE COLLECT -->
    <h4 class="mt-4">1. Information We Collect</h4>
    <p>We may collect the following information:</p>
    <ul>
        <li>Personal details (Full name, ID number, contact details)</li>
        <li>Financial information (Account number, transaction history)</li>
        <li>Login credentials (securely encrypted passwords)</li>
        <li>Device and usage data (IP address, browser type)</li>
    </ul>

    <!-- HOW WE USE -->
    <h4 class="mt-4">2. How We Use Your Information</h4>
    <p>Your information is used to:</p>
    <ul>
        <li>Provide secure banking services</li>
        <li>Process transactions and payments</li>
        <li>Verify your identity</li>
        <li>Improve user experience</li>
        <li>Comply with legal and regulatory requirements</li>
    </ul>

    <!-- SECURITY -->
    <h4 class="mt-4">3. Data Security</h4>
    <p>
        We use advanced encryption and security technologies to protect your data.
        Your personal and financial information is stored securely and access is strictly controlled.
    </p>

    <!-- SHARING -->
    <h4 class="mt-4">4. Sharing of Information</h4>
    <p>
        GlobalTrust does not sell your personal data. We may only share your information with:
    </p>
    <ul>
        <li>Trusted financial partners</li>
        <li>Regulatory authorities when required by law</li>
        <li>Fraud prevention and security services</li>
    </ul>

    <!-- RIGHTS -->
    <h4 class="mt-4">5. Your Rights</h4>
    <p>You have the right to:</p>
    <ul>
        <li>Access your personal data</li>
        <li>Request corrections</li>
        <li>Request deletion of your data</li>
        <li>Withdraw consent at any time</li>
    </ul>

    <!-- COOKIES -->
    <h4 class="mt-4">6. Cookies</h4>
    <p>
        Our website uses cookies to enhance your browsing experience and analyze site traffic.
        You can control cookie settings through your browser.
    </p>

    <!-- UPDATES -->
    <h4 class="mt-4">7. Policy Updates</h4>
    <p>
        We may update this Privacy Policy from time to time. Any changes will be posted on this page.
    </p>

    <!-- CONTACT -->
    <h4 class="mt-4">8. Contact Us</h4>
    <p>
        If you have any questions about this Privacy Policy, please contact us:
    </p>
    <ul>
        <li>Email: support@globaltrust.com</li>
        <li>Phone: +27 12 345 6789</li>
        <li>Location: Cape Town, South Africa</li>
    </ul>

    <hr />

    

</div>
<h1>@ViewData["Title"]</h1>

<p>Use this page to detail your site's privacy policy.</p>
