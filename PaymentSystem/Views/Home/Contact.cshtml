@{
    ViewData["Title"] = "Contact Us";
}

<style>
    /* ===== HERO HEADER ===== */
    .contact-hero {
        background: linear-gradient(135deg, #0d6efd, #0a58ca);
        color: white;
        padding: 60px 20px;
        border-radius: 20px;
        text-align: center;
        margin-bottom: 40px;
    }

    .contact-card {
        border-radius: 18px;
        transition: 0.3s;
    }

        .contact-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
        }

    .icon-box {
        width: 45px;
        height: 45px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #0d6efd;
        color: white;
        margin-bottom: 10px;
    }

    iframe {
        width: 100%;
        border: 0;
    }
</style>

<div class="container mt-4">

    <!-- HERO -->
    <div class="contact-hero">
        <h1 class="fw-bold">Get in Touch with GlobalTrust</h1>
        <p class="mb-0">
            We’re here to help you 24/7 — banking support made simple, fast, and secure.
        </p>
    </div>

    <!-- TOP INFO CARDS -->
    <div class="row g-3 mb-4">

        <div class="col-md-4">
            <div class="card contact-card p-4 text-center shadow-sm">
                <div class="icon-box mx-auto">
                    <i class="bi bi-geo-alt"></i>
                </div>
                <h6>Our Office</h6>
                <p class="text-muted mb-0">Cape Town, South Africa</p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card contact-card p-4 text-center shadow-sm">
                <div class="icon-box mx-auto">
                    <i class="bi bi-envelope"></i>
                </div>
                <h6>Email Support</h6>
                <p class="text-muted mb-0">support@globaltrust.com</p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card contact-card p-4 text-center shadow-sm">
                <div class="icon-box mx-auto">
                    <i class="bi bi-telephone"></i>
                </div>
                <h6>Call Us</h6>
                <p class="text-muted mb-0">+27 12 345 6789</p>
            </div>
        </div>

    </div>

    <!-- MAIN SECTION -->
    <div class="row g-4">

        <!-- FORM -->
        <div class="col-md-7">

            <div class="card contact-card shadow-sm p-4">

                <h4 class="mb-3">Send us a message</h4>
                <p class="text-muted">
                    Fill in the form below and our support team will respond within 24 hours.
                </p>

                <form method="post" asp-controller="Home" asp-action="Contact">

                    <div class="mb-3">
                        <label class="form-label">Full Name</label>
                        <input name="FullName" class="form-control" placeholder="John Doe" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input name="Email" type="email" class="form-control" placeholder="john@email.com" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Subject</label>
                        <input name="Subject" class="form-control" placeholder="How can we help?" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Message</label>
                        <textarea name="Message" rows="5" class="form-control" placeholder="Write your message..." required></textarea>
                    </div>

                    <button class="btn btn-primary w-100 rounded-pill">
                        Send Message
                    </button>

                </form>

            </div>

        </div>

        <!-- INFO SIDE -->
        <div class="col-md-5">

            <div class="card contact-card shadow-sm p-4">

                <h5 class="mb-3">Why Contact Us?</h5>

                <ul class="text-muted">
                    <li>✔ Instant banking support</li>
                    <li>✔ Secure transaction help</li>
                    <li>✔ Account assistance 24/7</li>
                    <li>✔ Fraud protection support</li>
                </ul>

                <hr />

                <h5>Working Hours</h5>
                <p class="text-muted">
                    Monday - Friday: 08:00 - 18:00<br />
                    Saturday: 09:00 - 14:00<br />
                    Sunday: Closed
                </p>

                <hr />

                <h5>Follow Us</h5>
                <div class="d-flex gap-2">

                    <a class="btn btn-outline-primary btn-sm rounded-circle"><i class="bi bi-facebook"></i></a>
                    <a class="btn btn-outline-info btn-sm rounded-circle"><i class="bi bi-twitter"></i></a>
                    <a class="btn btn-outline-danger btn-sm rounded-circle"><i class="bi bi-instagram"></i></a>
                    <a class="btn btn-outline-dark btn-sm rounded-circle"><i class="bi bi-linkedin"></i></a>

                </div>

            </div>

        </div>

    </div>

    <!-- MAP -->
    <div class="mt-5">

        <div class="text-center mb-3">
            <h4 class="fw-bold">Visit Our Headquarters</h4>
            <p class="text-muted">GlobalTrust Head Office — Cape Town</p>
        </div>

        <div class="card shadow-sm overflow-hidden contact-card">

            <iframe height="350"
                    src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3309.769!2d18.4241!3d-33.9249!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x1dcc5d5c9f1b1b1b%3A0x0!2sCape%20Town!5e0!3m2!1sen!2sza!4v1700000000000">
            </iframe>

        </div>

    </div>

</div>