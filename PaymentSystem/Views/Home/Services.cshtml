@{
    ViewData["Title"] = "Services";
}

<div class="container mt-5">

    <!-- HEADER -->
    <div class="text-center mb-5">
        <h1 class="fw-bold">Our Services</h1>
        <p class="text-muted">
            GlobalTrust gives you everything you need to manage, move, and secure your money globally.
        </p>
    </div>

    <!-- CORE SERVICES -->
    <div class="row g-4">

        <div class="col-md-4">
            <div class="card shadow p-4 text-center h-100">
                <h4>💸 Instant Transfers</h4>
                <p>Send and receive money globally within seconds, 24/7.</p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow p-4 text-center h-100">
                <h4>🏦 Digital Accounts</h4>
                <p>Open multiple accounts and manage all your finances in one place.</p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow p-4 text-center h-100">
                <h4>🔒 Secure Payments</h4>
                <p>Bank-level encryption and fraud protection for every transaction.</p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow p-4 text-center h-100">
                <h4>📊 Smart Analytics</h4>
                <p>Track spending habits and get financial insights in real-time.</p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow p-4 text-center h-100">
                <h4>💳 Virtual Cards</h4>
                <p>Create secure virtual cards for online shopping and subscriptions.</p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow p-4 text-center h-100">
                <h4>🌍 Global Payments</h4>
                <p>Pay anywhere in multiple currencies with low fees.</p>
            </div>
        </div>

    </div>

    <!-- BENEFITS SECTION -->
    <div class="mt-5 text-center">

        <h2 class="fw-bold mb-3">Why Choose GlobalTrust?</h2>

        <div class="row mt-4">

            <div class="col-md-4">
                <h5>⚡ Fast & Reliable</h5>
                <p class="text-muted">Transactions processed in real-time without delays.</p>
            </div>

            <div class="col-md-4">
                <h5>🔐 Maximum Security</h5>
                <p class="text-muted">Your data and money are protected with advanced encryption.</p>
            </div>

            <div class="col-md-4">
                <h5>🌐 Global Access</h5>
                <p class="text-muted">Access your account anywhere in the world, anytime.</p>
            </div>

        </div>
    </div>

    <!-- CALL TO ACTION -->
    <div class="text-center mt-5 p-5 bg-light rounded">

        <h3 class="fw-bold">Start using GlobalTrust today</h3>
        <p class="text-muted">Join thousands of users already managing their money smarter.</p>

        <a asp-controller="Auth" asp-action="Register"
               class="btn btn-primary rounded-pill px-5 mt-2">
            Get Started
        </a>

    </div>

</div>