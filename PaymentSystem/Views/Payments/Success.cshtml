@{
    ViewData["Title"] = "Payment Successful";
    Layout = null; // ❌ removes navbar + footer completely
}

<style>
    body {
        margin: 0;
        font-family: 'Segoe UI', sans-serif;
        background: linear-gradient(135deg, #0d6efd, #001f54);
        height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .success-card {
        width: 100%;
        max-width: 520px;
        background: #ffffff;
        border-radius: 18px;
        padding: 35px;
        box-shadow: 0 20px 50px rgba(0,0,0,0.3);
        text-align: center;
        animation: fadeIn 0.5s ease-in-out;
    }

    .check-icon {
        font-size: 60px;
        color: #28a745;
        margin-bottom: 10px;
    }

    h2 {
        margin: 10px 0;
        color: #1f2d3d;
    }

    .subtitle {
        color: #6c757d;
        margin-bottom: 25px;
    }

    .info-box {
        text-align: left;
        background: #f4f6fb;
        padding: 15px;
        border-radius: 12px;
        margin: 10px 0;
        font-size: 14px;
    }

    .label {
        font-weight: bold;
        color: #0d6efd;
    }

    .status {
        color: #ff9800;
        font-weight: bold;
    }

    .btn-dashboard {
        display: inline-block;
        margin-top: 25px;
        padding: 12px 20px;
        background: #0d6efd;
        color: white;
        border-radius: 10px;
        text-decoration: none;
        font-weight: 600;
        transition: 0.3s;
    }

    .btn-dashboard:hover {
        background: #0046b3;
    }

    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(15px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>

<div class="success-card">

    <div class="check-icon">✔</div>

    <h2>Payment Successful</h2>
    <p class="subtitle">Your international transfer has been submitted</p>

    <div class="info-box">
        <span class="label">Recipient:</span>
        <div>@TempData["Recipient"]</div>
    </div>

    <div class="info-box">
        <span class="label">Bank:</span>
        <div>@TempData["Bank"]</div>
    </div>

    <div class="info-box">
        <span class="label">Amount:</span>
        <div>R @TempData["Amount"]</div>
    </div>

    <div class="info-box">
        <span class="label">Status:</span>
        <div class="status">Pending Verification</div>
    </div>

    <a href="/UserDashboard/Index" class="btn-dashboard">
        Go to Dashboard
    </a>

</div>