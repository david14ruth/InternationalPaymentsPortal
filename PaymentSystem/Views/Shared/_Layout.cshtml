@using Microsoft.AspNetCore.Http

@{
    var role = Context.Session.GetString("Role");
    var user = Context.Session.GetString("User");
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - GlobalTrust</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">

    <style>
            body {
                background-color: #f8f9fa;
            }

            .navbar-brand img {
                height: 45px;
            }

            .nav-link.active {
                color: #0d6efd !important;
                font-weight: bold;
            }

            .nav-link:hover {
                color: #0d6efd !important;
            }

            footer {
                font-size: 14px;
            }

                footer a {
                    text-decoration: none;
                    color: #adb5bd;
                }

                    footer a:hover {
                        color: #0d6efd !important;
                    }
    </style>
</head>

<body>

    <!-- ================= NAVBAR ================= -->
    <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm sticky-top">
        <div class="container">

            <!-- LOGO -->
            <a class="navbar-brand d-flex align-items-center" asp-controller="Home" asp-action="Index">
                <img src="~/image/image_Logo.jpeg" class="rounded-circle me-2" />
                <span class="fw-bold">GlobalTrust</span>
            </a>

            <!-- TOGGLE -->
            <button class="navbar-toggler" data-bs-toggle="collapse" data-bs-target="#nav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <!-- LINKS -->
            <div class="collapse navbar-collapse" id="nav">

                <ul class="navbar-nav me-auto">

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Services">Services</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Privacy">Privacy</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Contact">Contact</a>
                    </li>

                    <!-- ================= USER DASHBOARD (ONLY USER) ================= -->
                    @if (role == "User")
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="UserDashboard" asp-action="Index">
                                Dashboard
                            </a>
                        </li>
                    }

                    <!-- ================= ADMIN PANEL ================= -->
                    @if (role == "Admin" || role == "SuperAdmin")
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Admin" asp-action="Index">
                                Admin Panel
                            </a>
                        </li>
                    }

                </ul>

                <!-- ================= RIGHT SIDE ================= -->
                <div class="d-flex gap-2">

                    @if (string.IsNullOrEmpty(user))
                    {
                        <a class="btn btn-outline-primary rounded-pill px-3"
                               asp-controller="Auth" asp-action="Register">
                            <i class="bi bi-person-plus me-1"></i>
                            Register
                        </a>

                        <a class="btn btn-primary rounded-pill px-3"
                               asp-controller="Auth" asp-action="Login">
                            <i class="bi bi-box-arrow-in-right me-1"></i>
                            Login
                        </a>
                    }
                    else
                    {
                        <span class="btn btn-light rounded-pill px-3">
                            👤 @user (@role)
                        </span>

                        <a class="btn btn-danger rounded-pill px-3"
                               asp-controller="Auth" asp-action="Logout">
                            Logout
                        </a>
                    }

                </div>

            </div>
        </div>
    </nav>

    <!-- ================= MAIN ================= -->
    <main class="container py-4">
        @RenderBody()
    </main>

    <!-- ================= FOOTER ================= -->
    <footer class="bg-dark text-white mt-5 pt-5 pb-3">

        <div class="container">

            <div class="row text-center text-md-start">

                <div class="col-md-4 mb-3">
                    <h5>GlobalTrust</h5>
                    <p class="text-muted">Secure digital banking for global transactions.</p>
                </div>

                <div class="col-md-4 mb-3">
                    <h6>Quick Links</h6>
                    <ul class="list-unstyled">
                        <li><a asp-controller="Home" asp-action="Index">Home</a></li>
                        <li><a asp-controller="Home" asp-action="Services">Services</a></li>
                        <li><a asp-controller="Home" asp-action="Privacy">Privacy</a></li>
                        <li><a asp-controller="Home" asp-action="Contact">Contact</a></li>
                    </ul>
                </div>

                <div class="col-md-4 mb-3">
                    <h6>Contact</h6>
                    <p class="text-muted">Cape Town, South Africa</p>
                    <p class="text-muted">support@globaltrust.com</p>
                    <p class="text-muted">+27 12 345 6789</p>
                </div>

            </div>

            <hr class="border-secondary" />

            <div class="text-center text-muted">
                © 2026 GlobalTrust. All rights reserved.
            </div>

        </div>
    </footer>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>