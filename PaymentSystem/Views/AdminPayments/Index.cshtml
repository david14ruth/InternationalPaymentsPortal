@model List<PaymentSystem.Models.Payment>

@using PaymentSystem.Models

@{
    Layout = null;
    var role = Context.Session.GetString("Role");
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Admin Payments</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <style>
        body {
            background: linear-gradient(135deg, #eef2ff, #f8f9ff);
            font-family: 'Segoe UI', sans-serif;
        }

        .container-box {
            max-width: 1200px;
            margin: 40px auto;
            background: white;
            padding: 25px;
            border-radius: 16px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.1);
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }

        .title {
            font-size: 22px;
            font-weight: 600;
            color: #0d6efd;
        }

        .back-btn {
            background: #0d6efd;
            color: white;
            padding: 8px 15px;
            border-radius: 10px;
            text-decoration: none;
        }

        .back-btn:hover {
            background: #084298;
        }

        thead {
            background: #0d6efd;
            color: white;
        }

        th, td {
            padding: 12px !important;
            vertical-align: middle;
        }

        .badge-pending { background: #ffc107; color: black; }
        .badge-verified { background: #17a2b8; color: white; }
        .badge-swift { background: #0d6efd; color: white; }
        .badge-completed { background: #28a745; color: white; }
        .badge-rejected { background: #dc3545; color: white; }

        .action-btn {
            font-size: 12px;
            padding: 5px 10px;
            border-radius: 8px;
        }
    </style>
</head>

<body>

<div class="container-box">

    <!-- HEADER -->
    <div class="header">
        <div class="title">💳 Admin SWIFT Payments</div>

        <a href="javascript:history.back()" class="back-btn">⬅ Back</a>
    </div>

    <!-- TABLE -->
    <div class="table-responsive">

        <table class="table table-hover table-bordered">

            <thead>
                <tr>
                    <th>#</th>
                    <th>User</th>
                    <th>Recipient</th>
                    <th>Bank</th>
                    <th>Amount</th>
                    <th>Status</th>
                    <th>Date</th>
                    <th>Action</th>
                </tr>
            </thead>

            <tbody>
            @{
                int i = 1;
            }

            @foreach (var p in Model)
            {
                <tr>
                    <td>@i</td>
                    <td>@p.UserId</td>
                    <td>@p.RecipientName</td>
                    <td>@p.BankName</td>
                    <td><b>R @p.Amount</b></td>

                    <!-- STATUS (ENUM SAFE) -->
                    <td>
                        @switch (p.Status)
                        {
                            case PaymentStatus.Pending:
                                <span class="badge badge-pending">Pending</span>
                                break;

                            case PaymentStatus.Verified:
                                <span class="badge badge-verified">Verified</span>
                                break;

                            case PaymentStatus.SentToSWIFT:
                                <span class="badge badge-swift">SWIFT Sent</span>
                                break;

                            case PaymentStatus.Completed:
                                <span class="badge badge-completed">Completed</span>
                                break;

                            case PaymentStatus.Rejected:
                                <span class="badge badge-rejected">Rejected</span>
                                break;
                        }
                    </td>

                    <td>@p.DateCreated.ToString("dd MMM yyyy")</td>

                    <!-- ACTIONS -->
                    <td>

                        @if (p.Status == PaymentStatus.Pending)
                        {
                            <form asp-action="Verify" method="post" style="display:inline;">
                                <input type="hidden" name="id" value="@p.Id" />
                                <button class="btn btn-warning action-btn">Verify</button>
                            </form>
                        }

                        @if (p.Status == PaymentStatus.Verified)
                        {
                            <form asp-action="SendToSwift" method="post" style="display:inline;">
                                <input type="hidden" name="id" value="@p.Id" />
                                <button class="btn btn-primary action-btn">SWIFT</button>
                            </form>
                        }

                        @if (p.Status == PaymentStatus.SentToSWIFT)
                        {
                            <form asp-action="Complete" method="post" style="display:inline;">
                                <input type="hidden" name="id" value="@p.Id" />
                                <button class="btn btn-success action-btn">Complete</button>
                            </form>
                        }

                        @if (p.Status != PaymentStatus.Completed && p.Status != PaymentStatus.Rejected)
                        {
                            <form asp-action="Reject" method="post" style="display:inline;">
                                <input type="hidden" name="id" value="@p.Id" />
                                <button class="btn btn-danger action-btn">Reject</button>
                            </form>
                        }

                    </td>
                </tr>

                i++;
            }

            </tbody>

        </table>

    </div>

</div>

</body>
</html>