@model PaymentSystem.Models.User

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Create User</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">

    <style>
            body {
                background: linear-gradient(135deg, #0d6efd, #ffffff);
                font-family: 'Segoe UI', sans-serif;
                min-height: 100vh;
            }

            /* TOP BACK BUTTON */
            .top-bar {
                position: absolute;
                top: 20px;
                left: 20px;
            }

                .top-bar a {
                    border-radius: 30px;
                    padding: 8px 16px;
                    background: white;
                    color: #0d6efd;
                    text-decoration: none;
                    font-weight: 600;
                    box-shadow: 0 5px 15px rgba(0,0,0,0.1);
                }

            /* CARD */
            .form-container {
                max-width: 520px;
                margin: 90px auto;
                background: white;
                padding: 35px;
                border-radius: 18px;
                box-shadow: 0 20px 50px rgba(0,0,0,0.15);
            }

            /* LOGO */
            .logo {
                text-align: center;
                margin-bottom: 15px;
            }

                .logo img {
                    width: 70px;
                    height: 70px;
                    object-fit: cover;
                    border-radius: 50%;
                    border: 2px solid #0d6efd;
                }

            /* HEADER */
            .header {
                text-align: center;
                margin-bottom: 25px;
            }

                .header h2 {
                    color: #0d6efd;
                    font-weight: 700;
                }

                .header p {
                    color: #555;
                    font-size: 14px;
                }

            /* INPUT */
            .form-control {
                border-radius: 12px;
                padding: 12px;
                border: 1px solid #ccc;
            }

                .form-control:focus {
                    border-color: #0d6efd;
                    box-shadow: 0 0 8px rgba(13,110,253,0.3);
                }

            /* BUTTON */
            .btn-primary {
                border-radius: 30px;
                padding: 10px;
                font-weight: 600;
                background: #0d6efd;
                border: none;
            }

                .btn-primary:hover {
                    background: #084298;
                }

            label {
                font-weight: 500;
            }

    </style>
</head>

<body>

    <!-- BACK BUTTON -->
    <div class="top-bar">
        <a asp-controller="Admin" asp-action="Index">← Back</a>
    </div>

    <!-- FORM CARD -->
    <div class="form-container">

        <!-- LOGO -->
        <div class="logo">
            <img src="~/image/image_Logo.jpeg" alt="Logo" />
        </div>

        <!-- HEADER -->
        <div class="header">
            <h2>User Registration</h2>
            <p>Create a secure customer account</p>
        </div>

        <!-- FORM -->
        <form asp-action="CreateUser" method="post">

            <div class="mb-3">
                <label>Full Name</label>
                <input asp-for="Name" class="form-control" placeholder="Enter full name" />
            </div>

            <div class="mb-3">
                <label>Email Address</label>
                <input asp-for="Email" class="form-control" placeholder="Enter email" />
            </div>

            <div class="mb-3">
                <label>Password</label>
                <input asp-for="Password" type="password" class="form-control" placeholder="Enter password" />
            </div>

            <button class="btn btn-primary w-100">
                💾 Save User
            </button>

        </form>

    </div>

</body>
</html>