@model List<PaymentSystem.Models.Payment>

@{
    ViewData["Title"] = "Payments";
}

<h2 class="mb-3">💳 Customer Payments</h2>

<table class="table table-striped table-bordered">

    <thead class="table-dark">
        <tr>
            <th>#</th>
            <th>Recipient</th>
            <th>Account</th>
            <th>Bank</th>
            <th>SWIFT</th>
            <th>Amount</th>
            <th>Currency</th>
            <th>Status</th>
            <th>Date</th>
        </tr>
    </thead>

    <tbody>
        @{
            int i = 1;
        }

        @foreach (var p in Model)
        {
            <tr>
                <td>@i</td>
                <td>@p.RecipientName</td>
                <td>@p.AccountNumber</td>
                <td>@p.BankName</td>
                <td>@p.SwiftCode</td>
                <td>@p.Amount</td>
                <td>@p.Currency</td>
                <td>
                    <span class="badge bg-warning">@p.Status</span>
                </td>
                <td>@p.DateCreated</td>
            </tr>

            i++;
        }
    </tbody>

</table>